---
import { fetchMangasByTeam, getFileUrl } from "../lib/api/client";
import type { MangaItem } from "../stores/tierStore";
import TierVsOrchestrator from "../components/TierVsOrchestrator.svelte";
import "../styles/global.css";

// Fetch teams red + blue in parallel
const [redMangas, blueMangas] = await Promise.all([
  fetchMangasByTeam("red"),
  fetchMangasByTeam("blue"),
]);

// Merge and map to MangaItem — dedupe by manga id
const seen = new Set<number>();
const items: MangaItem[] = [];

for (const manga of [...redMangas, ...blueMangas]) {
  if (seen.has(manga.id)) continue;
  seen.add(manga.id);
  items.push({
    id: String(manga.id),
    mangaId: manga.id,
    name: manga.name,
    slug: manga.slug,
    coverUrl: getFileUrl(manga.cover_hash),
    teamId: manga.team_id,
    weeklyIsActive: manga.weekly_is_active,
  });
}

// Active weekly first, then inactive; alphabetical within each group
items.sort((a, b) => {
  if (a.weeklyIsActive !== b.weeklyIsActive) {
    return a.weeklyIsActive ? -1 : 1;
  }
  return a.name.localeCompare(b.name);
});
